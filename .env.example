# dotfiles-vm configuration
# Copy to .env and edit, then run: make create

VM_NAME="kde-dotfiles-test"
VM_RAM="4096" # MB
VM_CPUS="4"
VM_DISK="40" # GB
VM_USER="dev"
VM_PASS="changeme"
DOTFILES_PATH="${HOME}/path/to/dotfiles"

# Path to a local Debian ISO (optional)
# If set, installs from this ISO instead of downloading over the network
# ISO_PATH="${HOME}/Downloads/debian-13.4.0-amd64-netinst.iso"
